{
  "name": "test",
  "private": true,
  "version": "0.4.4",
  "type": "module",
  "scripts": {
    "prepare": "rm -rf .husky && husky install && husky add .husky/pre-commit \"npx lint-staged\" && husky add .husky/pre-push \"npm run ci:deploy\"",
    "dev": "vite",
    "build": "tsc && vite build",
    "ci:init": "mb-ci init",
    "ci:deploy": "mb-ci deploy"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.29.3",
    "axios": "^1.4.0",
    "classnames": "^2.3.2",
    "less": "^4.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^6.30.3",
    "react-router-dom": "^6.30.3",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.2.0",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "mb-ci": "^0.1.1",
    "prettier": "^2.8.8",
    "typescript": "^5.9.3",
    "vite": "^4.5.14"
  },
  "lint-staged": {
    "**/*.{ts,tsx,json}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "pnpm@7.15.0+sha1.4a7d55a86a8d2e8e0d95e1e69d9797245f133398"
}
